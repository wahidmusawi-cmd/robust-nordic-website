# Stripe – löydät nämä Stripe-dashboardista (dashboard.stripe.com/apikeys)
# TEST-tila: käytä pk_test_ ja sk_test_ avaimia
# LIVE-tila: vaihda pk_live_ ja sk_live_ avaimiin ennen julkaisua

STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret – luo Stripe-dashboardissa (Developers > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# Sivuston base URL (Vercel asettaa tämän automaattisesti VERCEL_URL:na)
NEXT_PUBLIC_BASE_URL=https://robust-nordic-website.vercel.app

# Hallintapaneeli (/admin) – pakollinen tuotannossa
ADMIN_PASSWORD=vahva-salasana
# Valinnainen: erillinen avain istuntoevästeiden allekirjoitukseen.
# Jos tätä ei aseteta, käytetään ADMIN_PASSWORDia.
# ADMIN_SESSION_SECRET=pitka-satunnainen-merkkijono
